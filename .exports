# Shared public environment defaults.

export EDITOR="${EDITOR:-vim}"
export VISUAL="${VISUAL:-$EDITOR}"
export DOTFILES="${DOTFILES:-$HOME/.dotfiles-public}"

if [[ "$(uname -s)" == "Darwin" ]]; then
    export TERMINAL="${TERMINAL:-Warp.app}"
fi

export DOTNET_CLI_TELEMETRY_OPTOUT=1
export DOTNET_NOLOGO=1

path_add() {
    [[ -d "$1" ]] || return 0
    case ":$PATH:" in
        *":$1:"*) ;;
        *) export PATH="$1:$PATH" ;;
    esac
}

path_add "$DOTFILES/bin"
path_add "$HOME/.local/bin"
path_add "$HOME/bin"
path_add "$HOME/.cargo/bin"
path_add "$HOME/go/bin"
path_add "$HOME/.dotnet/tools"
path_add "/opt/homebrew/bin"
path_add "/opt/homebrew/sbin"
path_add "/usr/local/bin"
path_add "/usr/local/sbin"

if [[ -n "${PNPM_HOME:-}" ]]; then
    path_add "$PNPM_HOME"
elif [[ -d "$HOME/.local/share/pnpm/bin" ]]; then
    export PNPM_HOME="$HOME/.local/share/pnpm"
    path_add "$PNPM_HOME/bin"
fi
